# AI Poker Player — variáveis de ambiente
# Copie para .env e preencha os valores. Ordem: Groq > OpenAI > outra API > Ollama.

# --- Groq (Llama 4 Scout) — prioridade ---
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- OpenAI (GPT-4o, gpt-4o-mini) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Outra API (OpenAI-compatible, ex.: Llama Vision) ---
LLAMA_VISION_API_BASE_URL=
LLAMA_VISION_API_KEY=
LLAMA_VISION_MODEL=meta-llama/Llama-3.2-11B-Vision-Instruct

# Debug: salvar crops das regiões em capturas/debug_regions/<timestamp> (1/true/yes para ativar)
# DEBUG_SAVE_REGIONS=
