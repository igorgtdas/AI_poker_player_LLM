# AI Poker Player — variáveis de ambiente
# Copie para .env e preencha os valores. O arquivo .env não é commitado no Git.

# --- Groq (Llama 4 Scout) — prioridade ---
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Outra API (OpenAI-compatible, ex.: Llama Vision) ---
LLAMA_VISION_API_BASE_URL=
LLAMA_VISION_API_KEY=
LLAMA_VISION_MODEL=meta-llama/Llama-3.2-11B-Vision-Instruct
